# Copy to .env and set values. Never commit .env.

NODE_ENV=development
PORT=3000

# Required in production (min ~32 random characters). Used to sign session cookies.
SESSION_SECRET=replace-with-long-random-string-at-least-32-chars

# Optional: default password for seeded buyer1 / seller1 (admin & support use fixed passwords from seed script)
# SEED_PASSWORD=Auction123!

# How often to auto-close auctions past end time (ms). Default 60000.
# AUCTION_CLOSE_INTERVAL_MS=60000
